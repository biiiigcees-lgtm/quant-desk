FROM node:18-alpine AS builder
WORKDIR /app
COPY package*.json ./
COPY apps/ui/package*.json ./apps/ui/
COPY quant-core/package*.json ./quant-core/
RUN npm ci
COPY . .
RUN npm run build:quant-core
RUN cd apps/ui && npm run build

FROM node:18-alpine AS runtime
WORKDIR /app
COPY package*.json ./
COPY apps/ui/package*.json ./apps/ui/
COPY quant-core/package*.json ./quant-core/
RUN npm ci --production
COPY --from=builder /app/apps/ui/.next ./.next
COPY --from=builder /app/apps/ui/public ./public
COPY --from=builder /app/apps/ui/package.json ./package.json
COPY --from=builder /app/quant-core/dist ./quant-core/dist
ENV NODE_ENV=production
EXPOSE 3000
CMD ["npm", "run", "start"]
