{
  "name": "quant-core",
  "version": "1.0.0",
  "description": "LEVEL 4 Quant-Core – Masked Pulse AI Market Intelligence",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/market.d.ts",
      "default": "./dist/types/market.js"
    },
    "./engines": {
      "types": "./dist/engines/insight.d.ts",
      "default": "./dist/engines/insight.js"
    },
    "./kalshi": {
      "types": "./dist/kalshi/countdown.d.ts",
      "default": "./dist/kalshi/countdown.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.22.4",
    "ml-matrix": "^6.10.4",
    "kalmanjs": "^1.1.0",
    "ws": "^8.16.0",
    "axios": "^1.6.5",
    "prom-client": "^15.1.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "fast-check": "^3.15.0"
  }
}