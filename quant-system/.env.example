# Kalshi connectivity
KALSHI_API_KEY=demo-key
KALSHI_WS_URL=wss://api.elections.kalshi.com/ws
CONTRACT_IDS=KXBTC-26MAY0912-T100000,KXBTC-26MAY0912-T101000

# Core cadence
POLL_INTERVAL_MS=1000
PRICE_HISTORY_LENGTH=100

# Trading/risk thresholds
INITIAL_BANK=1000
MAX_POSITION_SIZE=100
MAX_DAILY_LOSS=30
MIN_CONFIDENCE=0.55
MIN_AGREEMENT=0.60
MIN_SCORE=40
RISK_LIMIT=0.02

# Indicators
EMA_SHORT_PERIOD=3
EMA_LONG_PERIOD=21
RSI_PERIOD=14
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9

# Strategy weights
MOMENTUM_WEIGHT=0.25
MEAN_REVERSION_WEIGHT=0.25
LIQUIDITY_WEIGHT=0.25
TIME_DECAY_WEIGHT=0.25

# Logging
LOG_LEVEL=info

# Runtime
SIMULATION_MODE=true
API_ENABLED=true
API_HOST=127.0.0.1
API_PORT=8787
